# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=...

# App URL (for CORS, redirects)
NEXT_PUBLIC_APP_URL=https://uaeangler.com

# Push Notifications (internal webhook secret — must match DB setting app.push_webhook_secret)
PUSH_WEBHOOK_SECRET=your-random-secret-here

# Google AdSense (optional — ads only render when configured)
NEXT_PUBLIC_GOOGLE_ADS_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_SLOT_HOME=1234567890
